<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews -Indexes
    </IfModule>

    RewriteEngine On

    # Handle Angular and Vue history mode:
    # Redirect Trailing Slashes If Not A Folder...
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [L,R=301]

    # Send Requests To Front Controller...
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L]

    # ====================
    # Image Serving Rules
    # ====================
    
    # Serve images from uploads directory (for hosting)
    # هذا القسم مهم عند رفع المشروع للاستضافة
    RewriteCond %{REQUEST_URI} ^/uploads/(.*)$
    RewriteCond %{DOCUMENT_ROOT}/../uploads/%1 -f
    RewriteRule ^uploads/(.*)$ ../uploads/$1 [L]

    # Security: Prevent execution of uploaded files
    <LocationMatch "^/uploads/">
        <IfModule mod_php.c>
            php_flag engine off
        </IfModule>
        <IfModule mod_deflate.c>
            SetEnv no-gzip 1
        </IfModule>
        ForceType application/octet-stream
    </LocationMatch>

    # ====================
    # Caching Headers
    # ====================
    
    # Cache static assets for 1 year
    <IfModule mod_expires.c>
        ExpiresActive on
        
        # Images
        ExpiresByType image/png "access plus 1 year"
        ExpiresByType image/jpg "access plus 1 year"
        ExpiresByType image/jpeg "access plus 1 year"
        ExpiresByType image/gif "access plus 1 year"
        ExpiresByType image/webp "access plus 1 year"
        ExpiresByType image/svg+xml "access plus 1 year"
        
        # Other assets
        ExpiresByType application/pdf "access plus 1 month"
    </IfModule>

    # Alternative cache headers if mod_expires is not available
    <IfModule mod_headers.c>
        # Cache images for 1 year
        <FilesMatch "\.(jpg|jpeg|png|gif|webp|svg)$">
            Header set Cache-Control "public, max-age=31536000"
        </FilesMatch>
        
        # Cache PDFs for 1 month
        <FilesMatch "\.pdf$">
            Header set Cache-Control "public, max-age=2628000"
        </FilesMatch>
    </IfModule>

    # ====================
    # Security Headers
    # ====================
    
    # Prevent access to sensitive files
    <FilesMatch "^\.">
        Order allow,deny
        Deny from all
    </FilesMatch>

    # Prevent access to Laravel files
    <FilesMatch "(artisan|composer\.(json|lock)|package\.json|\.env)">
        Order allow,deny
        Deny from all
    </FilesMatch>

    # ====================
    # Compression
    # ====================
    
    <IfModule mod_deflate.c>
        # Don't compress images and PDFs (already compressed)
        SetEnvIfNoCase Request_URI \
            \.(?:gif|jpe?g|png|webp|svg|pdf)$ no-gzip dont-vary
    </IfModule>
</IfModule>